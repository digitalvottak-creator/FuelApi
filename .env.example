# DATABASE
DATABASE_URL=sqlite:///./fuel_api.db
# Для продакшена: postgresql://user:password@localhost/fuel_api

# LIQPAY (получить на https://www.liqpay.com/uk/)
LIQPAY_PUBLIC_KEY=your_public_key_here
LIQPAY_PRIVATE_KEY=your_private_key_here

# URLs
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# JWT
SECRET_KEY=your-secret-key-change-this

# Парсинг
PARSER_UPDATE_INTERVAL=3600  # Обновление цен каждый час

# Redis (опционально для кэширования)
REDIS_URL=redis://localhost:6379

# Логирование
LOG_LEVEL=INFO
